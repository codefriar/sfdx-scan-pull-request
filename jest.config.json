{
  "roots": ["<rootDir>/tests", "<rootDir>/src"],
  "clearMocks": true,
  "moduleFileExtensions": ["js", "ts"],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "testMatch": [
    "**/tests/**/*.(spec|test).[jt]s?(x)",
    "**/?(*.)+(spec|test).[jt]s?(x)"
  ],
  "transform": {
    "^.+\\.(t|j)sx?$": "@swc/jest"
  }
}
